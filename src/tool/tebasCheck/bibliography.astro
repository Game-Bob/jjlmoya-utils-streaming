---
import { TEBAS_CHECK_TOOL } from './index';
import type { KnownLocale } from '../../types';

interface Props {
  locale?: KnownLocale;
}

const { locale = 'es' } = Astro.props;
const content = await TEBAS_CHECK_TOOL.entry.i18n[locale]?.();
---

{
  content && content.bibliography.length > 0 && (
    <div class="tebas-bibliography">
      <h3 class="bibliography-title">{content.bibliographyTitle || 'Bibliography'}</h3>
      <ul class="bibliography-list">
        {content.bibliography.map((item) => (
          <li>
            <a href={item.url} target="_blank" rel="noopener noreferrer">
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )
}

<style>
  .tebas-bibliography {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--tebas-border);
  }

  .bibliography-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--tebas-text);
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .bibliography-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
  }

  .bibliography-list a {
    color: var(--tebas-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    transition: opacity 0.2s;
  }

  .bibliography-list a:hover {
    opacity: 0.8;
  }
</style>
