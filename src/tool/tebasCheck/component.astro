---
import { Icon } from 'astro-icon/components';
import type { TebasCheckUI } from './types';
import targetIps from './ips.json';

interface Props {
  ui?: Record<string, string>;
}

const { ui: rawUi } = Astro.props;
const ui = (rawUi ?? {}) as TebasCheckUI;
---

<div 
  id="tebas-app" 
  class="tebas-container" 
  data-targets={JSON.stringify(targetIps)}
  data-ui={JSON.stringify(ui)}
>
  <div class="tebas-card">
    <div class="tebas-card-bg-icon">
      <Icon name="mdi:cctv" />
    </div>

    <div class="tebas-content">
      <div id="status-arena" class="tebas-status-view">
        <div id="loading-state" class="tebas-loading">
          <div class="tebas-spinner-wrapper">
            <div class="tebas-spinner">
              <Icon name="mdi:eye-refresh-outline" class="animate-spin" />
            </div>
            <div class="tebas-ping-ring"></div>
          </div>
          <div class="tebas-loading-text">
            <h2 class="tebas-title-main">{ui?.scanning}</h2>
            <p id="loading-subtext" class="tebas-subtitle-pulse">{ui?.seekingBlocks}</p>
          </div>
        </div>

        <div id="result-state" class="tebas-results hidden">
          <div id="res-blocked" class="tebas-result-box blocked hidden">
            <div class="tebas-result-icon-badge">
               <Icon name="mdi:account-alert" class="tebas-result-main-icon" />
               <div class="tebas-badge-overlay"><Icon name="mdi:gavel" /></div>
            </div>
            <div class="tebas-result-info">
              <h3 class="tebas-result-status">{ui?.blockedTitle}</h3>
              <div class="tebas-result-details">
                <p class="tebas-font-bold">{ui?.blockedDiagnosis}</p>
                <p id="blocked-reason" class="tebas-text-sm">{ui?.blockedReason}</p>
              </div>
            </div>
          </div>

          <div id="res-no-internet" class="tebas-result-box error hidden">
            <div class="tebas-result-icon-badge">
               <Icon name="mdi:router-wireless-off" class="tebas-result-main-icon" />
            </div>
            <div class="tebas-result-info">
              <h3 class="tebas-result-status">{ui?.noInternetTitle}</h3>
              <p class="tebas-text-sm">{ui?.noInternetReason}</p>
            </div>
          </div>

          <div id="res-success" class="tebas-result-box success hidden">
            <div class="tebas-result-icon-badge">
               <Icon name="mdi:emoticon-happy-outline" class="tebas-result-main-icon" />
               <div class="tebas-badge-overlay"><Icon name="mdi:shield-check" /></div>
            </div>
            <div class="tebas-result-info">
              <h3 class="tebas-result-status">{ui?.successTitle}</h3>
              <p class="tebas-text-sm">{ui?.successReason}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="tebas-actions">
        <button id="retry-btn" class="tebas-btn hidden">
          <Icon name="mdi:reload" />
          <span>{ui?.retryBtn}</span>
        </button>
      </div>

      <div class="tebas-note">
        <Icon name="mdi:alert-decagram-outline" class="tebas-note-icon" />
        <div class="tebas-note-content">
          <span class="tebas-note-label">{ui?.authorNoteTitle}</span>
          <p class="tebas-note-text">{ui?.authorNoteText}</p>
        </div>
      </div>
    </div>

    <div class="tebas-console">
      <div class="tebas-console-header">
        <div class="tebas-console-dots">
          <span></span><span></span><span></span>
        </div>
        <span class="tebas-console-version">{ui?.consoleHeader}</span>
      </div>
      <div id="console-output" class="tebas-console-body"></div>
    </div>
  </div>
</div>

<script>
  import { TebasEngine } from './engine';
  import { TebasUIManager } from './ui-manager';
  import type { ProbeResult, TebasCheckUI } from './types';

  const app = document.getElementById('tebas-app');
  const ips = JSON.parse(app?.dataset.targets || '[]');
  const apiUi = JSON.parse(app?.dataset.ui || '{}') as TebasCheckUI;

  const engine = new TebasEngine(ips);
  const ui = new TebasUIManager('console-output');

  const els = {
    loading: document.getElementById('loading-state'),
    results: document.getElementById('result-state'),
    resBlocked: document.getElementById('res-blocked'),
    resNoInternet: document.getElementById('res-no-internet'),
    resSuccess: document.getElementById('res-success'),
    loadingText: document.getElementById('loading-subtext'),
    retryBtn: document.getElementById('retry-btn'),
    blockedReason: document.getElementById('blocked-reason'),
  };

  const messages = [
    apiUi.statusNegotiating,
    apiUi.statusDodging,
    apiUi.statusCheckingPirate,
    apiUi.statusPinging,
    apiUi.statusConsulting,
    apiUi.statusCheckingFee,
    apiUi.statusCalculating,
    apiUi.statusDeciphering,
  ];

  const resetState = () => {
    els.loading?.classList.remove('hidden');
    els.results?.classList.add('hidden');
    els.resBlocked?.classList.add('hidden');
    els.resNoInternet?.classList.add('hidden');
    els.resSuccess?.classList.add('hidden');
    els.retryBtn?.classList.add('hidden');
    ui.clearLog();
    ui.log(apiUi.logStarted);
  };

  const handleNoInternet = (msgInterval: ReturnType<typeof setInterval>) => {
    clearInterval(msgInterval);
    els.loading?.classList.add('hidden');
    els.results?.classList.remove('hidden');
    els.resNoInternet?.classList.remove('hidden');
    els.retryBtn?.classList.remove('hidden');
    ui.log(apiUi.logNoInternet, 'error');
  };

  interface DiagSummary {
    isp: string;
    poisoned: boolean;
    results: ProbeResult[];
    isBlocked: boolean;
  }

  const renderDiagnosticResults = (summary: DiagSummary) => {
    if (summary.isp) ui.log(apiUi.logIspFound + summary.isp);
    if (summary.poisoned) ui.log(apiUi.logDnsPoisoned, 'error');

    summary.results.forEach((res) => {
      const type = res.status === 'blocked' ? 'error' : 'success';
      const msg = res.status === 'blocked' ? apiUi.logIpBlocked : apiUi.logIpActive;
      ui.log(msg.replace('{ip}', res.ip), type);
    });
  };

  const showFinalState = (summary: DiagSummary) => {
    els.loading?.classList.add('hidden');
    els.results?.classList.remove('hidden');
    els.retryBtn?.classList.remove('hidden');

    if (summary.isBlocked) {
      ui.log(apiUi.logAlertInterference, 'error');
      els.resBlocked?.classList.remove('hidden');
    } else {
      ui.log(apiUi.logClean, 'success');
      els.resSuccess?.classList.remove('hidden');
    }
  };

  const runDiagnostic = async () => {
    resetState();
    const msgInterval = setInterval(() => {
      if (els.loadingText) {
        els.loadingText.innerText = messages[Math.floor(Math.random() * messages.length)] || '';
      }
    }, 800);

    try {
      const summary = await engine.runFullDiagnostic();
      if (!summary.internet) {
        handleNoInternet(msgInterval);
        return;
      }
      renderDiagnosticResults(summary);
      clearInterval(msgInterval);
      showFinalState(summary);
    } catch {
      ui.log(apiUi.logDiagError, 'error');
      clearInterval(msgInterval);
    }
  };

  runDiagnostic();
  els.retryBtn?.addEventListener('click', runDiagnostic);
</script>

